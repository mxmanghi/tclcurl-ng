package require tcltest
namespace import ::tcltest::*

source [file join [file dirname [file normalize [info script]]] support.tcl]

::tclcurl::test::load_package

proc ::tclcurl::test::normalizedBody {body} {
    set normalized [string map [list "\r\n" "\n" "\r" "\n"] $body]
    set lines {}
    foreach line [split $normalized "\n"] {
        if {$line eq {}} {
            continue
        }
        lappend lines $line
    }
    return [join $lines "\n"]
}

proc ::tclcurl::test::cookieEnginePath {name} {
    # let's have the token represented in hex form for brevity
    set token [format "%X" [clock clicks]]
    return [file join [pwd] "${name}-${token}.cookies"]
}

proc ::tclcurl::test::httpServerHost {} {
    if {![regexp {^https?://([^/:]+)} [::tclcurl::test::server::base_url] -> host]} {
        error "unable to determine HTTP test host"
    }
    return $host
}

proc ::tclcurl::test::netscapeCookieRecord {name value} {
    return "[::tclcurl::test::httpServerHost]\tFALSE\t/\tFALSE\t0\t${name}\t${value}"
}

proc ::tclcurl::test::netscapePersistentCookieRecord {name value} {
    set tomorrow [expr {[clock seconds] + 86400}]
    return "[::tclcurl::test::httpServerHost]\tFALSE\t/\tFALSE\t${tomorrow}\t${name}\t${value}"
}

test cookies-1.1 {cookies stay on one easy handle and are not shared implicitly} -constraints http_server -body {
    set primaryBody {}
    set secondaryBody {}
    set primary [curl::init]
    set secondary [curl::init]
    set primaryCookieFile [::tclcurl::test::cookieEnginePath primary]
    set secondaryCookieFile [::tclcurl::test::cookieEnginePath secondary]
    set code [catch {
        $primary configure \
            -url [::tclcurl::test::server::base_url cookie-set/session/alpha] \
            -cookiefile $primaryCookieFile \
            -bodyvar primaryBody \
            -noprogress 1
        $primary perform

        set primaryBody {}
        $primary configure \
            -url [::tclcurl::test::server::base_url cookie-echo] \
            -bodyvar primaryBody \
            -noprogress 1
        $primary perform

        $secondary configure \
            -url [::tclcurl::test::server::base_url cookie-echo] \
            -cookiefile $secondaryCookieFile \
            -bodyvar secondaryBody \
            -noprogress 1
        $secondary perform

        list \
            [expr {[::tclcurl::test::normalizedBody $primaryBody] eq "cookie=session=alpha"}] \
            [expr {[::tclcurl::test::normalizedBody $secondaryBody] eq "cookie="}]
    } result options]
    catch {$secondary cleanup}
    catch {$primary cleanup}
    file delete -force $primaryCookieFile $secondaryCookieFile
    return -options $options $result
} -result {1 1}

test cookies-1.2 {share cookies lets a second easy handle reuse cookies set by the first} -constraints http_server -body {
    set firstBody {}
    set secondBody {}
    set share [curl::shareinit]
    set first [curl::init]
    set second [curl::init]
    set firstCookieFile [::tclcurl::test::cookieEnginePath shared-first]
    set secondCookieFile [::tclcurl::test::cookieEnginePath shared-second]
    set code [catch {
        $share share cookies

        $first configure \
            -url [::tclcurl::test::server::base_url cookie-set/session/bravo] \
            -share $share \
            -cookiefile $firstCookieFile \
            -bodyvar firstBody \
            -noprogress 1
        $first perform

        $second configure \
            -url [::tclcurl::test::server::base_url cookie-echo] \
            -share $share \
            -cookiefile $secondCookieFile \
            -bodyvar secondBody \
            -noprogress 1
        $second perform

        list [expr {[::tclcurl::test::normalizedBody $firstBody] eq "set-cookie=session=bravo"}] \
             [expr {[::tclcurl::test::normalizedBody $secondBody] eq "cookie=session=bravo"}]
    } result options]
    catch {$second cleanup}
    catch {$first cleanup}
    catch {$share cleanup}
    file delete -force $firstCookieFile $secondCookieFile
    return -options $options $result
} -result {1 1}

test cookies-1.3 {-cookielist injects a cookie into the easy handle cookie engine} -constraints http_server -body {
    set body {}
    set cookieFile [::tclcurl::test::cookieEnginePath cookielist]
    set handle [curl::init]
    set code [catch {
        $handle configure   -url [::tclcurl::test::server::base_url cookie-echo] \
                            -cookiefile $cookieFile \
                            -cookielist [::tclcurl::test::netscapeCookieRecord manual delta] \
                            -bodyvar body \
                            -noprogress 1
        set rc [$handle perform]
        list $rc [expr {[::tclcurl::test::normalizedBody $body] eq "cookie=manual=delta"}] \
                 [expr {[llength [$handle getinfo cookielist]] > 0}]
    } result options]
    catch {$handle cleanup}
    file delete -force $cookieFile
    return -options $options $result
} -result {0 1 1}

test cookies-1.4 {-cookielist FLUSH writes in-memory cookies to the -cookiejar file} -constraints http_server -body {
    set body {}
    set cookieJar [::tclcurl::test::cookieEnginePath cookiejar]
    set handle [curl::init]
    set jarContents {}
    set code [catch {
        $handle configure   -url        [::tclcurl::test::server::base_url cookie-echo] \
                            -cookiejar  $cookieJar \
                            -cookielist [::tclcurl::test::netscapeCookieRecord flushme echo] \
                            -bodyvar    body \
                            -noprogress 1
        $handle perform
        $handle configure -cookielist FLUSH
        set jarChan [open $cookieJar r]
        set jarContents [read $jarChan]
        close $jarChan
        list [file exists $cookieJar] [expr {[string first "flushme" $jarContents] >= 0}]
    } result options]
    catch {$handle cleanup}
    file delete -force $cookieJar
    return -options $options $result
} -result {1 1}

test cookies-1.5 {-cookiesession ignores session cookies loaded from -cookiefile} -constraints http_server -body {
    set body {}
    set cookieFile [::tclcurl::test::cookieEnginePath cookiesession]
    set handle [curl::init]
    set cookieChan [open $cookieFile w]
    puts $cookieChan "# Netscape HTTP Cookie File"
    puts $cookieChan [::tclcurl::test::netscapeCookieRecord session stale]
    puts $cookieChan [::tclcurl::test::netscapePersistentCookieRecord persistent alive]
    close $cookieChan
    set code [catch {
        $handle configure   -url [::tclcurl::test::server::base_url cookie-echo] \
                            -cookiefile $cookieFile \
                            -cookiesession 1 \
                            -bodyvar body \
                            -noprogress 1
        $handle perform
        list [expr {[string first "session=stale" $body] < 0}] \
             [expr {[string first "persistent=alive" $body] >= 0}]
    } result options]
    catch {$handle cleanup}
    file delete -force $cookieFile
    return -options $options $result
} -result {1 1}

cleanupTests
