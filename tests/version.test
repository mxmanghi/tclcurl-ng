package require tcltest
namespace import ::tcltest::*
source [file join [file dirname [file normalize [info script]]] support.tcl]
::tclcurl::test::load_package
package require TclCurl

test version-1.01 {: Test that curl::version returns something} -body {
	set result [curl::version]

	return $result
} -match regexp -result {^TclCurl Version \d+\.\d+\.\d+(-DEV)? \(libcurl/\d+\.\d+\.\d+(-DEV)? .*?\)$}

cleanupTests
